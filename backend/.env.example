PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/axentralab
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRE=7d
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Email Services (choose one or both)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@axentralab.com

# Legacy Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# AI Services
OPENAI_API_KEY=sk-your_openai_api_key
LANGCHAIN_API_KEY=ls_your_langchain_api_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_chat_id

# Redis (for job queues)
REDIS_URL=redis://localhost:6379

# AI Automation Settings
AI_PROPOSAL_MODEL=gpt-4
AI_QUOTE_MODEL=gpt-3.5-turbo
AI_CHAT_MODEL=gpt-3.5-turbo
ENABLE_AUTO_PROPOSALS=true
ENABLE_AUTO_FOLLOWUP=true
FOLLOWUP_DELAY_HOURS=24
